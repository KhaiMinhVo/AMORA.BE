{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5444;Database=AmoraCoreDb;Username=postgres;Password=postgres",
    "MongoDb": "mongodb://localhost:27017"
  },
  "Jwt": {
    "Issuer": "Amora",
    "Audience": "Amora",
    "Key": "dev-only-secret-key-change-me-please-use-a-longer-256-bit-key"
  },
  "MongoDb": {
    "DatabaseName": "AmoraChatDb",
    "MessagesCollectionName": "Messages"
  },
  "AWS": {
    "Profile": "default",
    "Region": "ap-southeast-1",
    "BucketName": "amora-voice-bucket"
  },
  "RabbitMQ": {
    "Url": "amqp://guest:guest@localhost:5672//"
  },
  "Webhooks": {
    "Secret": "change-me-webhook-secret"
  },
  "Iap": {
    "AllowDevBypass": true,
    "AppleSharedSecret": "",
    "GooglePackageName": "com.amora.app",
    "Products": {
      "amora_gems_100": 100,
      "amora_gems_500": 550,
      "amora_gems_1200": 1400
    }
  }
}
